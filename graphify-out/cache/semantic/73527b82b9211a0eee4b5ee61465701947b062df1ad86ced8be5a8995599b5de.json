{"nodes": [{"id": "commercialization_roadmap_glm_5_2_rareb_platform", "label": "Rareb Investment & Debt Management Platform", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_supabase_auth", "label": "Supabase Auth (email/password, cookie SSR)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 28", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_tenancy_model", "label": "Tenancy Model (per-user isolation via user_id)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 29", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_rls_policies", "label": "Row Level Security Policies (auth.uid() = user_id)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 29", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_profiles_role", "label": "profiles.role Enum (owner|admin|viewer)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 30", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_investment_categories_global", "label": "investment_categories (Global Shared Table - Data Leak Risk)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 31", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "investment_categories is not scoped to any tenant (no user_id, no org_id). This is a data-isolation bug disguised as a feature \u2014 the day a second tenant signs up, both see/edit the same rows. Must be migrated to per-org in Step 1 of commercialization."}, {"id": "commercialization_roadmap_glm_5_2_cron_layer", "label": "Cron Alert Layer (GitHub Action + /api/cron/alerts + Gmail SMTP)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 32", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_audit_log", "label": "audit_log Table (No RLS, Appears Unwritten)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 36", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "audit_log table exists but has no RLS policies and no evidence it is being written to in any server actions. For a B2B finance product, an enforced tenant-scoped audit log is a compliance selling feature, not an afterthought. Should be wired in Step 1 RLS sweep."}, {"id": "commercialization_roadmap_glm_5_2_model_a_shared_saas", "label": "Model A \u2014 Shared Multi-Tenant SaaS (Recommended)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 48", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Recommended as starting point due to lowest marginal cost per customer. Schema work (org_id isolation) is unavoidable for any serious B2B play regardless of model chosen. Isolation shifts from user_id to org_id via RLS."}, {"id": "commercialization_roadmap_glm_5_2_model_b_white_label", "label": "Model B \u2014 White-Label Dedicated Deployment", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 54", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each customer gets their own Supabase project + Netlify site. Operational cost grows linearly with customer count. Suited for regulated enterprise clients (banks, government finance offices) needing data sovereignty. Deferred until a paying customer demands it."}, {"id": "commercialization_roadmap_glm_5_2_model_c_hybrid", "label": "Model C \u2014 Hybrid (Shared Core + Dedicated Tier)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 60", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Build Model A first, architect so exact same codebase can be deployed as single-tenant for enterprise. Strategy most successful B2B SaaS converge on (GitLab, Sentry, Supabase). Defer Model B cost until a paying customer demands it."}, {"id": "commercialization_roadmap_glm_5_2_model_d_source_license", "label": "Model D \u2014 Source License / Self-Hosted", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 66", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Niche but powerful in the GCC/regional market where banks and family offices demand on-prem. Lowest infra cost; highest support cost. Only worth pursuing once brand traction exists."}, {"id": "commercialization_roadmap_glm_5_2_organizations_table", "label": "organizations Table (New - Tenant Boundary)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 79", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_org_memberships_table", "label": "org_memberships Join Table (user_id, org_id, role)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 80", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_current_org_ids_fn", "label": "current_org_ids() SQL Helper Function", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 82", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Define once as a SQL function so every RLS policy calls it \u2014 described as the single highest-leverage change in the whole project. Replaces per-policy auth.uid() = user_id checks."}, {"id": "commercialization_roadmap_glm_5_2_require_role_guard", "label": "requireRole() Server-Side Guard", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 86", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_stripe_billing", "label": "Stripe Billing Integration (Checkout + Customer Portal + subscriptions table)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 91", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_transactional_email_provider", "label": "Transactional Email Provider (Resend/Postmark) per-tenant sender domains", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 90", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Gmail App Passwords will throttle at scale with many tenants. Moving to Resend/Postmark with per-tenant sender domains improves deliverability and enables per-org branding of notification emails."}, {"id": "commercialization_roadmap_glm_5_2_signup_onboarding_flow", "label": "Signup + Onboarding Flow (/signup page)", "file_type": "concept", "source_file": "COMMERCIALIZATION_ROADMAP(GLM 5.2).md", "source_location": "line 88", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "commercialization_roadmap_glm_5_2_invitation_flow", "label": "Invitation Flow (/invite email magic link)", 