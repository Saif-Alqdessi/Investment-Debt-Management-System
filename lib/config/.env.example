# ── Supabase Configuration ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
# Required for the cron job (bypasses RLS — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── White-Label Branding (Model B) ─────────────────────────────────────────────
# Each client deployment sets these — no code changes needed between clients.
NEXT_PUBLIC_APP_NAME=Rareb
NEXT_PUBLIC_APP_TAGLINE=Private Wealth Management
NEXT_PUBLIC_APP_TAGLINE_AR=إدارة الثروات الخاصة
NEXT_PUBLIC_PRIMARY_COLOR=#2563eb
# Leave empty to use the text-only wordmark (first letter of APP_NAME)
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_COPYRIGHT_NAME=Rareb Private Wealth
NEXT_PUBLIC_SUPPORT_EMAIL=support@rareb.app
NEXT_PUBLIC_EMAIL_FROM_NAME=Rareb Investments

# ── Deployment URL ──────────────────────────────────────────────────────────────
# Used in email CTA links (e.g. "Open Dashboard" button)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Email Notifications (Nodemailer / Gmail SMTP) ──────────────────────────────
# Generate an App Password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ── Cron Job Security ───────────────────────────────────────────────────────────
# Random secret used to authenticate the GitHub Action → /api/cron/alerts
CRON_SECRET=your-random-secret-here
